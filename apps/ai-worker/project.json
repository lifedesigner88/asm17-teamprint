{
  "name": "ai-worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ai-worker",
  "projectType": "application",
  "targets": {
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node scripts/docker-build.mjs apps/ai-worker/Dockerfile persona-mirror-ai-worker:dev",
          "node scripts/docker-run-ai-worker.mjs"
        ],
        "parallel": false
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "envFile": "apps/ai-worker/.env",
        "commands": [
          "cd apps/ai-worker && uv run python -u -m worker.main"
        ],
        "parallel": false
      }
    }
  }
}
