{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node scripts/wait-for-port.mjs 5432 127.0.0.1 60000"
          },
          {
            "command": "uv run --project apps/backend uvicorn main:app --reload --host 0.0.0.0 --port 8000 --app-dir apps/backend --env-file .env"
          }
        ],
        "parallel": false
      }
    }
  }
}
