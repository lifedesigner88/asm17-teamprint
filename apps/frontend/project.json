{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/src",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "envFile": "apps/frontend/.env",
        "commands": [
          {
            "command": "node scripts/wait-for-port.mjs ${BACKEND_PORT} 127.0.0.1 60000"
          },
          {
            "command": "pnpm --dir apps/frontend dev --port ${VITE_PORT:-3000}"
          }
        ],
        "parallel": false
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node scripts/wait-for-port.mjs 8000 127.0.0.1 60000"
          },
          {
            "command": "node scripts/docker-build.mjs apps/frontend/Dockerfile persona-mirror-frontend:dev"
          },
          {
            "command": "node scripts/docker-run-frontend.mjs"
          }
        ],
        "parallel": false
      }
    }
  }
}
